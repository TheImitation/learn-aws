{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowJs": true,
    "useDefineForClassFields": true,
    "types": ["vite/client", "node"],
    "paths": { "@content": ["../web/src/content.js"] }
  },
  "include": ["src", "vite.config.ts"]
}
